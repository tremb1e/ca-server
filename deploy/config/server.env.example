# ==========================
# Continuous Auth Server env
# ==========================
#
# docker-compose.yml mounts this file as /app/.env by default. To keep local
# secrets out of Git, copy it to deploy/config/server.env and run compose with:
#
#   CA_SERVER_ENV_FILE=server.env docker compose up -d

# Basic runtime settings
LOG_LEVEL=INFO
LOG_FORMAT=json
ENCRYPTION_KEY=Continuous_Authentication
MAX_REQUEST_SIZE=10485760
MAX_DECOMPRESSED_SIZE=10485760

# Training/authentication concurrency
TRAINING_MAX_CONCURRENT=1
AUTH_MAX_CONCURRENT=16
AUTH_MAX_CACHED_MODELS=16
AUTH_SESSION_TTL_SEC=600

# Read-only management API. Keep disabled until MANAGEMENT_API_KEY is set.
MANAGEMENT_API_ENABLED=false
# MANAGEMENT_API_KEY=change-to-a-long-random-token

# Processing thresholds. These can override ca_config.toml when needed.
PROCESSING_MIN_TOTAL_MB=100
PROCESSING_TARGET_MB=100
PROCESSING_HMOG_MAX_ROWS_PER_SUBJECT=0
PROCESSING_HMOG_MAX_ROWS_TOTAL=0

# Optional TLS. Place certificates under deploy/certs before enabling.
# TLS_CERTFILE=/app/certs/server.crt
# TLS_KEYFILE=/app/certs/server.key
# TLS_CA_CERTS=/app/certs/ca_bundle.pem
# TLS_KEYFILE_PASSWORD=changeit
